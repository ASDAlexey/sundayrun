{
  "name": "sundayrun",
  "version": "1.4.0",
  "description": "Воскресный парковый пробег — конвертер Excel-результатов в PDF-протокол с архивом (Angular 22, RU/EN).",
  "scripts": {
    "start": "bun scripts/write-version.ts && bun scripts/build-sqlite-assets.ts && bun scripts/build-pdf-assets.ts && ng serve",
    "build": "bun scripts/write-version.ts && bun scripts/build-sqlite-assets.ts && bun scripts/build-pdf-assets.ts && ng build --localize",
    "preview": "bun scripts/preview.ts",
    "watch": "ng build --watch --configuration development",
    "test": "ng test",
    "test:coverage": "ng test --coverage",
    "test:watch": "ng test --watch",
    "generate-i18n": "ng extract-i18n --output-path=src/locale --format=xlf",
    "prettier": "prettier -w \"./src/**/**.(html|scss|ts|json)\" --cache",
    "prettier:check": "prettier -c \"./src/**/**.(html|scss|ts|json)\"",
    "eslint": "eslint . --ext .html,.ts",
    "stylelint": "stylelint \"./src/**/**.scss\" --cache --fix",
    "stylelint:check": "stylelint \"./src/**/**.scss\" --cache",
    "jscpd": "jscpd ./src",
    "madge": "bun ./scripts/check-circular-dependencies.js",
    "check:code-quality": "bun run prettier && concurrently --kill-others-on-fail \"bun run eslint\" \"bun run stylelint:check\"",
    "prepare": "husky"
  },
  "private": true,
  "packageManager": "bun@1.3.14",
  "dependencies": {
    "@angular/cdk": "^22.0.0",
    "@angular/common": "^22.0.0",
    "@angular/compiler": "^22.0.0",
    "@angular/core": "^22.0.0",
    "@angular/forms": "^22.0.0",
    "@angular/localize": "^22.0.2",
    "@angular/material": "^22.0.0",
    "@angular/platform-browser": "^22.0.0",
    "@angular/router": "^22.0.0",
    "@sqlite.org/sqlite-wasm": "^3.53.0-build1",
    "chart.js": "^4.5.1",
    "chartjs-plugin-zoom": "^2.2.0",
    "drizzle-orm": "^0.45.2",
    "fflate": "^0.8.2",
    "hammerjs": "^2.0.8",
    "pdfjs-dist": "^6.1.200",
    "pdfmake": "^0.2.12",
    "rxjs": "~7.8.0",
    "sqlite-wasm-http": "^1.2.0",
    "tslib": "^2.3.0"
  },
  "devDependencies": {
    "@angular-eslint/builder": "^22.0.0",
    "@angular-eslint/eslint-plugin": "^22.0.0",
    "@angular-eslint/eslint-plugin-template": "^22.0.0",
    "@angular-eslint/template-parser": "^22.0.0",
    "@angular/build": "^22.0.5",
    "@angular/cli": "^22.0.5",
    "@angular/compiler-cli": "^22.0.0",
    "@angular/platform-server": "^22.0.5",
    "@angular/ssr": "^22.0.5",
    "@eslint-community/eslint-plugin-eslint-comments": "^4.7.2",
    "@prettier/plugin-oxc": "^0.1.4",
    "@trivago/prettier-plugin-sort-imports": "^6.0.2",
    "@types/bun": "^1.3.14",
    "@types/hammerjs": "^2.0.46",
    "@types/node": "^20.17.19",
    "@types/pdfmake": "^0.2",
    "@typescript-eslint/eslint-plugin": "^8.61.0",
    "@typescript-eslint/parser": "^8.61.0",
    "@typescript-eslint/utils": "^8.61.0",
    "@vitest/coverage-istanbul": "^4.1.9",
    "concurrently": "^10.0.3",
    "eslint": "8.57.1",
    "eslint-plugin-change-detection-strategy": "^0.1.5",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-local-rules": "file:./eslint-local-plugin",
    "eslint-plugin-optimize-regex": "^1.2.1",
    "husky": "^9.1.7",
    "jscpd": "^5.0.8",
    "jsdom": "^28.0.0",
    "madge": "^8.0.0",
    "prettier": "^3.8.1",
    "prettier-plugin-css-order": "^2.2.0",
    "prettier-plugin-organize-attributes": "^1.0.0",
    "prettier-plugin-sort-json": "^4.2.0",
    "pretty-quick": "^4.2.2",
    "stylelint": "^17.13.0",
    "stylelint-config-standard": "^40.0.0",
    "stylelint-scss": "^7.2.0",
    "typescript": "~6.0.2",
    "vitest": "^4.0.8",
    "vitest-auto-spy": "^1.9.2"
  }
}
