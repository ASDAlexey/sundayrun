{
  "customSyntax": "postcss-scss",
  "extends": ["stylelint-config-standard"],
  "plugins": ["stylelint-scss", "./stylelint-rules/no-m3-mixins.mjs"],
  "rules": {
    "at-rule-no-unknown": null,
    "scss/at-rule-no-unknown": true,
    "import-notation": null,
    "color-function-notation": null,
    "alpha-value-notation": "number",
    "color-no-hex": true,
    "color-named": "never",
    "property-no-vendor-prefix": true,
    "selector-class-pattern": null,
    "custom-property-pattern": [
      "^([a-zA-Z][a-zA-Z0-9]*)(-[a-zA-Z0-9]+)*$",
      {
        "message": "Expected custom property name to be kebab-case"
      }
    ],
    "no-descending-specificity": null,
    "declaration-block-no-redundant-longhand-properties": null,
    "selector-type-no-unknown": [
      true,
      {
        "ignoreTypes": ["router-outlet", "/^app-/"]
      }
    ],
    "selector-pseudo-class-no-unknown": [
      true,
      {
        "ignorePseudoClasses": ["host", "host-context"]
      }
    ],
    "property-disallowed-list": ["font-style", "font-weight", "font-size", "line-height", "letter-spacing"],
    "custom/no-m3-mixins": [true],
    "nesting-selector-no-missing-scoping-root": null,
    "selector-pseudo-element-disallowed-list": ["ng-deep"]
  }
}
